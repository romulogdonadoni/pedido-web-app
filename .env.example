# Domínio raiz do storefront (tenant vem no path: /{tenant})
ROOT_DOMAIN=whitelabel.com.br
NEXT_PUBLIC_ROOT_DOMAIN=whitelabel.com.br

# MinhaApi (cardápio público GET /store/{tenant}/menu e GET /stores)
NEXT_PUBLIC_API_URL=http://localhost:5247
# API_URL=http://localhost:5247

# Host público das fotos do cardápio (mesmo R2:PublicBaseUrl da MinhaApi)
# NEXT_PUBLIC_CDN_URL=https://pub-xxxxx.r2.dev

# Google Maps (marketplace + pins das lojas): enable Maps JavaScript API
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Dev local:
# http://localhost:3001/           → marketplace
# http://localhost:3001/{tenant}   → cardápio da loja
